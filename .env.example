# ==============================================================================
# Tastee Backend - Environment Configuration Template
# Sao chép file này thành .env và chỉnh sửa các giá trị phù hợp với hệ thống của bạn.
# ==============================================================================

# Cổng khởi chạy server Express
PORT=3000

# Môi trường chạy ứng dụng (development | production)
NODE_ENV="development"

# Đường dẫn kết nối cơ sở dữ liệu PostgreSQL
# Định dạng: postgresql://[user]:[password]@[host]:[port]/[database_name]
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/tastee_db"

# Cấu hình JWT (Json Web Token) bảo mật
# Hãy thay đổi các chuỗi khóa bí mật này khi triển khai thực tế (Production)
JWT_ACCESS_SECRET="tastee-access-secret-change-in-prod"
JWT_REFRESH_SECRET="tastee-refresh-secret-change-in-prod"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Đường dẫn đến các file CSV bộ dữ liệu từ Food.com (Dùng cho các script import)
# Có thể dùng đường dẫn tương đối (tính từ thư mục gốc dự án) hoặc tuyệt đối.
RAW_RECIPES_CSV="data/RAW_recipes.csv"
PP_RECIPES_CSV="data/PP_recipes.csv"
